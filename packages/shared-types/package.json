{
  "name": "@ssmp/shared-types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Zod schemas and TypeScript types for SSMP",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./openapi": {
      "types": "./dist/openapi.d.ts",
      "import": "./dist/openapi.js",
      "require": "./dist/openapi.js",
      "default": "./dist/openapi.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "openapi3-ts": "^4.6.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
